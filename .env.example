NEXT_PUBLIC_SITE_URL=https://waihub.dev

# Google AdSense（发布商 ID 需与 public/ads.txt 中 pub- 一致，前缀改为 ca-pub-）
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1038105604687667

# 广告单元 ID（在 AdSense → 广告 → 按单元 创建后获得）
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_BOTTOM=
