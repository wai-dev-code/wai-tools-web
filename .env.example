# 站点正式域名（用于 sitemap、canonical、Open Graph）
# 本地开发可设为 http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://waihub.dev

# Google AdSense（审核通过后从 AdSense 后台获取）
# 发布商 ID，格式 ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# 广告单元 ID（在 AdSense → 广告 → 按单元 创建后获得）
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_MID=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG=
